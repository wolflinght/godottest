ultimate_damage_coeff = 2.5
ultimate_ignore_def_ratio = 0.5
ultimate_aoe = 0
ultimate_apply_stun = false
ultimate_broadcast = "{caster}太极内劲爆发，一招「震字诀」轰在{target}身上，掌力直透五脏六腑！"
