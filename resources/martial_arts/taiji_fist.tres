weight = 15
broadcast_template = "{caster}双手画圆，「云手」连绵不断，击中{target}！"

[resource]
script = ExtResource("1")
art_name = "太极拳"
weapon_tag = 0
move_pool = [SubResource("move_1"), SubResource("move_2"), SubResource("move_3")]
